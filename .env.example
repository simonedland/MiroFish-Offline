# =============================================================
# MiroFish-Offline Configuration
# =============================================================
# Copy this file to .env and fill in your Azure OpenAI credentials.
# =============================================================

# Azure OpenAI configuration
AZURE_OPENAI_ENDPOINT=https://<your-resource>.services.ai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_CHAT_DEPLOYMENT=<your-chat-deployment-name>
AZURE_OPENAI_API_VERSION=2024-02-01

# CAMEL-AI Azure aliases (read directly by camel-ai library — must match AZURE_OPENAI_ENDPOINT above)
AZURE_OPENAI_BASE_URL=https://<your-resource>.services.ai.azure.com/
AZURE_API_VERSION=2024-02-01

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish
